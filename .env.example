# Configuração do Firebase via variáveis de ambiente.
# Estas variáveis sobrescrevem os valores de firebase-applet-config.json.
# Se não definidas, os valores do JSON são usados como fallback.

# Chave de API do Firebase (Web)
NEXT_PUBLIC_FIREBASE_API_KEY=""

# Domínio de autenticação (ex.: meu-projeto.firebaseapp.com)
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""

# ID do projeto Firebase
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""

# ID do app Web do Firebase
NEXT_PUBLIC_FIREBASE_APP_ID=""

# Bucket do Cloud Storage
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""

# Sender ID do Cloud Messaging
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""

# ID do banco Firestore (deixe vazio para usar o banco padrão "(default)")
NEXT_PUBLIC_FIRESTORE_DATABASE_ID=""
