# Configuração do Firebase via variáveis de ambiente.
# Estas variáveis sobrescrevem os valores de firebase-applet-config.json.
# Se não definidas, os valores do JSON são usados como fallback.

# Chave de API do Firebase (Web)
NEXT_PUBLIC_FIREBASE_API_KEY=""

# Domínio de autenticação (ex.: meu-projeto.firebaseapp.com)
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""

# ID do projeto Firebase
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""

# ID do app Web do Firebase
NEXT_PUBLIC_FIREBASE_APP_ID=""

# Bucket do Cloud Storage
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""

# Sender ID do Cloud Messaging
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""

# ID do banco Firestore (deixe vazio para usar o banco padrão "(default)")
NEXT_PUBLIC_FIRESTORE_DATABASE_ID=""

# --- Automação de jogos (/api/sync-games) ---

# JSON completo da service account do Firebase (Configurações do projeto →
# Contas de serviço → Gerar nova chave privada). Cole o JSON em uma linha.
# Necessária para o job bloquear jogos e inserir resultados no servidor.
FIREBASE_SERVICE_ACCOUNT_KEY=""

# Token da API football-data.org (gratuito em https://www.football-data.org/client/register).
# Usado para buscar automaticamente os resultados finais da Copa.
FOOTBALL_DATA_TOKEN=""

# Opcional: protege a rota /api/sync-games. Se definido, a rota exige
# Authorization: Bearer <CRON_SECRET> (enviado pelo Vercel Cron) ou ?key=<CRON_SECRET>.
CRON_SECRET=""
